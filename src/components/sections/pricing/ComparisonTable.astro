---
/**
 * ComparisonTable - 3-column feature comparison for service plans
 * Row = feature name, columns = Plan 1 | Plan 2 | Plan 3 (checkmark or custom text)
 */
import { Icon } from 'astro-icon/components';

export interface PlanCell {
  /** true = check, false = empty, string = custom text (e.g. "max. 25") */
  value: boolean | string;
}

export interface ComparisonRow {
  label: string;
  plan1: boolean | string;
  plan2: boolean | string;
  plan3: boolean | string;
}

interface Props {
  title: string;
  subtitle?: string;
  planNames: [string, string, string];
  recommendedIndex?: 0 | 1 | 2;
  rows: ComparisonRow[];
  includedNote?: string;
  ctaHref?: string;
  background?: 'default' | 'muted';
}

const {
  title,
  subtitle,
  planNames,
  recommendedIndex = 1,
  rows,
  includedNote,
  ctaHref = '/contact',
  background = 'default',
} = Astro.props;

const bgClass = background === 'muted' ? 'bg-surface' : 'bg-background';

function cellContent(val: boolean | string) {
  if (val === true) return 'check';
  if (val === false) return 'empty';
  return 'text';
}
---

<section class:list={['py-section', bgClass]}>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-3xl mx-auto mb-10">
      <h2 class="text-3xl sm:text-4xl font-bold text-text">{title}</h2>
      {subtitle && <p class="mt-4 text-lg text-text-muted">{subtitle}</p>}
      {includedNote && (
        <p class="mt-2 text-sm text-text-muted italic">{includedNote}</p>
      )}
    </div>

    <div class="overflow-x-auto rounded-lg border border-border">
      <table class="w-full text-left text-sm">
        <thead>
          <tr class="border-b border-border bg-surface">
            <th class="px-4 py-4 font-semibold text-text w-1/2 sm:w-2/5">Serviciu / Facilitate</th>
            {
              planNames.map((name, i) => (
                <th
                  class:list={[
                    'px-4 py-4 font-semibold text-text text-center whitespace-nowrap',
                    i === recommendedIndex && 'bg-primary/10 text-primary',
                  ]}
                >
                  <span class="block">{name}</span>
                  {i === recommendedIndex && (
                    <span class="block mt-1 text-xs font-normal text-primary">Recomandat</span>
                  )}
                </th>
              ))
            }
          </tr>
        </thead>
        <tbody>
          {
            rows.map((row, idx) => (
              <tr
                class:list={[
                  'border-b border-border last:border-b-0',
                  idx % 2 === 1 && 'bg-surface/50',
                ]}
              >
                <td class="px-4 py-3 text-text-muted">{row.label}</td>
                <td class="px-4 py-3 text-center">
                  {row.plan1 === true ? (
                    <Icon name="lucide:check" class="w-5 h-5 text-primary inline-block" />
                  ) : row.plan1 === false ? (
                    <span class="text-border">—</span>
                  ) : (
                    <span class="text-text-muted">{row.plan1}</span>
                  )}
                </td>
                <td class="px-4 py-3 text-center">
                  {row.plan2 === true ? (
                    <Icon name="lucide:check" class="w-5 h-5 text-primary inline-block" />
                  ) : row.plan2 === false ? (
                    <span class="text-border">—</span>
                  ) : (
                    <span class="text-text-muted">{row.plan2}</span>
                  )}
                </td>
                <td class="px-4 py-3 text-center">
                  {row.plan3 === true ? (
                    <Icon name="lucide:check" class="w-5 h-5 text-primary inline-block" />
                  ) : row.plan3 === false ? (
                    <span class="text-border">—</span>
                  ) : (
                    <span class="text-text-muted">{row.plan3}</span>
                  )}
                </td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>

    <div class="mt-8 text-center">
      <a
        href={ctaHref}
        class="inline-flex items-center justify-center px-6 py-3 rounded-md bg-primary text-white font-medium hover:bg-primary-dark transition-colors"
      >
        Solicită o ofertă
      </a>
    </div>
  </div>
</section>
