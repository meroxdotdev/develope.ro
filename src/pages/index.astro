---
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import Hero from '@sections/marketing/Hero.astro';
import LogoCloud from '@sections/marketing/LogoCloud.astro';
import HowItWorks from '@sections/marketing/HowItWorks.astro';
import IntegrationsGrid from '@sections/marketing/IntegrationsGrid.astro';
import FeaturesSection from '@sections/marketing/FeaturesSection.astro';
import BentoGrid from '@sections/marketing/BentoGrid.astro';
import PricingTable from '@sections/pricing/PricingTable.astro';
import TestimonialsSection from '@sections/social-proof/TestimonialsSection.astro';
import CTA from '@sections/marketing/CTA.astro';
import Newsletter from '@sections/marketing/Newsletter.astro';
import { siteConfig } from '@/config';

// 1. Hero — keep
const steps = [
  {
    title: 'Spune-ne ce ai nevoie',
    description:
      'Descrie proiectul sau infrastructura dorită. Îți răspundem rapid cu întrebări de clarificare dacă e cazul.',
    icon: 'lucide:message-circle',
  },
  {
    title: 'Primești o ofertă',
    description:
      'Îți trimitem o ofertă personalizată, fără obligații. Prețuri transparente și termene realiste.',
    icon: 'lucide:file-text',
  },
  {
    title: 'Livrăm și asigurăm suport',
    description:
      'Implementăm soluția și oferim mentenanță și suport conform pachetului ales.',
    icon: 'lucide:rocket',
  },
];

// 2. Trusted by — logo strip (placeholder logos; replace with real brand SVGs when available)
const trustedByLogos = [
  { name: 'WordPress', src: '/images/logos/logoipsum-1.svg' },
  { name: 'Shopify', src: '/images/logos/logoipsum-2.svg' },
  { name: 'Cloudflare', src: '/images/logos/logoipsum-3.svg' },
  { name: 'Docker', src: '/images/logos/logoipsum-4.svg' },
  { name: 'Kubernetes', src: '/images/logos/logoipsum-5.svg' },
  { name: 'Proxmox', src: '/images/logos/logoipsum-6.svg' },
  { name: 'Tailscale', src: '/images/logos/logoipsum-7.svg' },
  { name: 'Grafana', src: '/images/logos/logoipsum-8.svg' },
];

// 4. Integrations — 3 cards
const integrations = [
  {
    name: 'Cloudflare',
    logo: '/images/integrations/sentry.svg',
    category: 'Performance & Security',
    description: 'CDN global, caching și protecție DDoS integrate automat.',
    featured: true,
    href: '/servicii/web',
  },
  {
    name: 'Google Tag Manager',
    logo: '/images/integrations/google-analytics.svg',
    category: 'Marketing',
    description: 'Integrare pixeli GTM, Facebook Ads și Google Ads fără cod.',
    featured: true,
    href: '/servicii/web',
  },
  {
    name: 'WooCommerce / Shopify',
    logo: '/images/integrations/zapier.svg',
    category: 'eCommerce',
    description: 'Magazin online complet, cu plăți, transport și facturare integrate.',
    featured: true,
    href: '/servicii/web',
  },
];

// 5. "Everything you need" — 6-feature icon grid
const everythingFeatures = [
  {
    icon: 'lucide:search',
    title: 'SEO de la primul deploy',
    description:
      'Meta tags, sitemap, keywords și Open Graph configurate corect din start.',
  },
  {
    icon: 'lucide:shield',
    title: 'Securitate inclusă',
    description:
      'SSL, WAF, hardening și scanare de vulnerabilități pentru orice proiect.',
  },
  {
    icon: 'lucide:cloud',
    title: 'Infrastructură Cloud',
    description:
      'VM, storage, backup cloud și Zero Trust — scalabile după nevoile tale.',
  },
  {
    icon: 'lucide:activity',
    title: 'Monitorizare continuă',
    description:
      'Grafana, Prometheus și Uptime Kuma — știi instant dacă ceva nu merge.',
  },
  {
    icon: 'lucide:archive',
    title: 'Backup & Recuperare',
    description:
      'Strategie de backup cu Bareos și NAS. Datele tale sunt întotdeauna în siguranță.',
  },
  {
    icon: 'lucide:message-circle',
    title: 'Suport în română',
    description:
      'Echipă locală, răspuns rapid, comunicare clară — fără bariere lingvistice.',
  },
];

// 6. Soluții la cheie — BentoGrid: 1 large (stânga), 2 small (dreapta sus), 1 medium (dreapta jos) = layout ca în original
const bentoItems = [
  {
    title: 'Site Prezentare & Magazine Online',
    description:
      'WordPress, Shopify, Astro sau Hugo — alegem împreună platforma potrivită. Fiecare pachet include SSL, domeniu, email și configurare server.',
    icon: 'lucide:globe',
    size: 'large' as const,
    accent: 'primary' as const,
    href: '/servicii/web',
  },
  {
    title: 'Infrastructură la cheie',
    description:
      'Rețelistică, virtualizare (Proxmox, Docker, K8s), VPN și monitorizare. Tu te concentrezi pe business.',
    icon: 'lucide:server',
    size: 'small' as const,
    accent: 'blue' as const,
    href: '/servicii/infrastructura',
  },
  {
    title: 'Externalizare IT',
    description:
      'Suport, mentenanță și administrare adaptate companiei tale — fără costurile unui departament intern.',
    icon: 'lucide:users',
    size: 'small' as const,
    accent: 'purple' as const,
    href: '/servicii/externalizare-it',
  },
  {
    title: 'Audit & Consultanță',
    description:
      'Analizăm infrastructura sau site-ul tău și îți oferim un raport clar cu probleme identificate și soluții concrete.',
    icon: 'lucide:clipboard-check',
    size: 'medium' as const,
    accent: 'green' as const,
    href: '/contact',
  },
];

// 7. Pricing — 3 plans (Site Prezentare), custom price text
const pricingPlans = [
  {
    name: 'Start',
    monthlyPrice: null as number | null,
    customPrice: 'De la 299 €',
    description: 'Pentru afaceri la început de drum',
    features: [
      'Implementare site',
      'SEO inițial (MT, MD, keywords, sitemap)',
      'Pagini GDPR',
      'Backup lunar',
      'SSL + domeniu + email',
    ],
    cta: { label: 'Solicită ofertă', href: '/contact' },
  },
  {
    name: 'Business',
    monthlyPrice: null as number | null,
    customPrice: 'De la 499 €',
    description: 'Pentru afaceri care vor să crească',
    features: [
      'Tot din Plan 1',
      'Securitate web (WAF)',
      'SEO avansat (GTM, FB Pixel, AdWords)',
      'Integrare Newsletter',
      '+2 luni mentenanță gratuită',
    ],
    highlighted: true,
    badge: 'Recomandat',
    cta: { label: 'Solicită ofertă', href: '/contact' },
  },
  {
    name: 'Premium',
    monthlyPrice: null as number | null,
    customPrice: 'De la 799 €',
    description: 'Performanță maximă',
    features: [
      'Tot din Plan 2',
      'Live AI Chat',
      'Cloudflare CDN + Caching',
      'Uptime monitoring',
      '+3 luni mentenanță gratuită',
    ],
    cta: { label: 'Solicită ofertă', href: '/contact' },
  },
];

// 8. Testimonials — 4 cards
// TODO: replace with real testimonial
const testimonials = [
  {
    quote:
      'Am lansat magazinul online în 3 săptămâni. Totul a mers perfect, de la integrarea plăților până la configurarea transportului.',
    author: 'Andrei M.',
    role: 'Fondator',
    company: 'magazin de echipamente outdoor',
  },
  {
    quote:
      'Infrastructura noastră era un haos. Acum avem monitorizare, backup automat și știm instant dacă apare orice problemă.',
    author: 'Raluca D.',
    role: 'IT Manager',
    company: 'companie servicii',
  },
  {
    quote:
      'Ca antreprenor solo nu aveam timp să mă ocup de server și securitate. Developero gestionează totul și eu mă concentrez pe clienți.',
    author: 'Mihai C.',
    role: 'Consultant independent',
    company: 'freelance',
  },
  {
    quote:
      'SEO-ul a crescut vizibil după implementare. Traficul organic s-a dublat în primele 2 luni.',
    author: 'Elena P.',
    role: 'Marketing Manager',
    company: 'eCommerce',
  },
];
---

<MarketingLayout
  title={`${siteConfig.name} — ${siteConfig.description}`}
  description="Developero — soluții IT complete pentru afacerea ta: site și magazin online, infrastructură, externalizare IT. Oferte personalizate, fără obligații."
>
  <!-- 1. Hero -->
  <Hero
    title="Expertiza Web & Infrastructură IT pentru afacerea ta"
    subtitle="Site de prezentare, magazin online, infrastructură și externalizare IT. Lucrăm cu tehnologii moderne și oferim suport în limba română."
    primaryCTA={{ label: 'Solicită o ofertă', href: '/contact' }}
    secondaryCTA={{ label: 'Servicii Web', href: '/servicii/web' }}
  />

  <!-- 2. Trusted by — logo strip (marquee ca în original, fundal muted) -->
  <LogoCloud
    title="Tehnologii cu care lucrăm"
    logos={trustedByLogos}
    variant="marquee"
    speed="slow"
    pauseOnHover={true}
    grayscale={false}
    logoSize="lg"
    background="muted"
  />

  <!-- 3. Cum lucrăm -->
  <HowItWorks
    title="Cum lucrăm"
    subtitle="De la cerere la livrare, în pași simpli."
    steps={steps}
    variant="horizontal"
    background="muted"
  />

  <!-- 4. Integrations -->
  <IntegrationsGrid
    title="Integrări"
    subtitle="Lucrăm cu instrumentele pe care le cunoști și le integrezi ușor în proiecte."
    integrations={integrations}
    variant="detailed"
    invertOnDark={false}
    columns={3}
    background="default"
    footerLink={{ label: 'Vezi toate integrările →', href: '/servicii/web' }}
  />

  <!-- 5. Everything you need — 6-feature grid -->
  <FeaturesSection
    title="Tot ce ai nevoie"
    subtitle="De la SEO și securitate la cloud, monitorizare și suport în română."
    features={everythingFeatures}
    background="muted"
    footerLink={{ label: 'Vezi toate funcționalitățile →', href: '/servicii/web' }}
  />

  <!-- 6. Developer-First — 4 detailed feature blocks -->
  <BentoGrid
    title="Soluții la cheie"
    subtitle="Site, infrastructură, externalizare IT și audit — alegi ce ți se potrivește."
    items={bentoItems}
    background="default"
  />

  <!-- 7. Pricing -->
  <PricingTable
    title="Pachete Site Prezentare"
    subtitle="Prețurile sunt orientative. Contactați-ne pentru o ofertă personalizată."
    plans={pricingPlans}
    annualDiscount={0}
    defaultPeriod="monthly"
    background="muted"
    footerLink={{ label: 'Vezi toate pachetele →', href: '/servicii/web' }}
  />

  <!-- Note below pricing (handled in subtitle above) -->

  <!-- 8. Testimonials -->
  <TestimonialsSection
    title="Ce spun clienții"
    subtitle="Companii și antreprenori care lucrează cu Developero."
    testimonials={testimonials}
    limit={4}
    background="default"
    footerLink={{ label: 'Vezi toate testimonialele →', href: '/contact' }}
  />

  <!-- 9. Newsletter -->
  <Newsletter background="muted" />

  <!-- 10. Final CTA (optional; keep for consistency with original flow) -->
  <CTA
    title="Vrei să discutăm proiectul tău?"
    description="Contactează-ne și îți trimitem o ofertă personalizată, fără obligații."
    action={{ label: 'Contactează-ne', href: '/contact' }}
    background="default"
  />
</MarketingLayout>
