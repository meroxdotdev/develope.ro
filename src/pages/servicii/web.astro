---
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import PageHeader from '@sections/content/PageHeader.astro';
import ComparisonTable from '@sections/pricing/ComparisonTable.astro';
import FeaturesSection from '@sections/marketing/FeaturesSection.astro';
import CTA from '@sections/marketing/CTA.astro';
import { siteConfig } from '@/config';

const sitePrezentareRows = [
  { label: 'Implementare', plan1: true, plan2: true, plan3: true },
  { label: 'SEO inițial (meta tags, meta desc, keywords, sitemap)', plan1: true, plan2: true, plan3: true },
  { label: 'GDPR (pagini legale)', plan1: true, plan2: true, plan3: true },
  { label: 'Backup lunar', plan1: true, plan2: true, plan3: true },
  { label: 'Securitate web (WAF)', plan1: false, plan2: true, plan3: true },
  { label: 'SEO avansat (GTM, Facebook Pixel, AdWords)', plan1: false, plan2: true, plan3: true },
  { label: 'Integrare Newsletter', plan1: false, plan2: true, plan3: true },
  { label: '+2 luni mentenanță gratuită', plan1: false, plan2: true, plan3: true },
  { label: 'Live AI Chat', plan1: false, plan2: false, plan3: true },
  { label: 'Cloudflare (Caching + CDN)', plan1: false, plan2: false, plan3: true },
  { label: 'Uptime monitoring', plan1: false, plan2: false, plan3: true },
  { label: '+3 luni mentenanță gratuită', plan1: false, plan2: false, plan3: true },
];

const magazinRows = [
  { label: 'Implementare', plan1: true, plan2: true, plan3: true },
  { label: 'SEO inițial', plan1: true, plan2: true, plan3: true },
  { label: 'GDPR + pagini legale (SAL, SOL)', plan1: true, plan2: true, plan3: true },
  { label: 'Pagini magazin (produse, cont client, flow vânzare)', plan1: true, plan2: true, plan3: true },
  { label: 'Import produse', plan1: 'max. 25', plan2: 'max. 50', plan3: 'max. 100' },
  { label: 'Integrare plată, transport, facturare', plan1: true, plan2: true, plan3: true },
  { label: 'Search produse', plan1: true, plan2: true, plan3: true },
  { label: 'Backup lunar', plan1: false, plan2: true, plan3: true },
  { label: 'Securitate web (WAF)', plan1: false, plan2: true, plan3: true },
  { label: 'SEO avansat (GTM, Facebook Pixel, AdWords)', plan1: false, plan2: true, plan3: true },
  { label: 'Integrare Newsletter', plan1: false, plan2: true, plan3: true },
  { label: 'Abandoned Cart', plan1: false, plan2: true, plan3: true },
  { label: '+2 luni mentenanță gratuită', plan1: false, plan2: true, plan3: true },
  { label: 'Live AI Chat', plan1: false, plan2: false, plan3: true },
  { label: 'Cloudflare (Caching + CDN)', plan1: false, plan2: false, plan3: true },
  { label: 'Uptime monitoring', plan1: false, plan2: false, plan3: true },
  { label: '+3 luni mentenanță gratuită', plan1: false, plan2: false, plan3: true },
];

const extraWebFeatures = [
  {
    icon: 'lucide:search',
    title: 'Audit extern',
    description: 'Audit de funcționalități, tehnic și design pentru site-ul tău existent.',
  },
  {
    icon: 'lucide:layout',
    title: 'Landing Page',
    description: 'Pagini de prezentare dedicate campaniilor și conversiilor.',
  },
  {
    icon: 'lucide:settings',
    title: 'Mentenanță lunară',
    description: 'Suport continuu: actualizări, backup, monitorizare și intervenții la cerere.',
  },
];
---

<MarketingLayout
  title={`Servicii Web — ${siteConfig.name}`}
  description="Site prezentare (WordPress, Astro, Hugo), magazin online (WordPress, Shopify), landing page, audit și mentenanță. Soluții web complete pentru afacerea ta."
>
  <PageHeader
    title="Servicii Web"
    subtitle="Site de prezentare, magazin online și servicii suplimentare. Te ajutăm să alegi platforma potrivită (WordPress, Shopify, Astro, Hugo sau custom) și livrăm totul gata de folosit: SSL, domeniu, email."
    align="center"
    maxWidth="lg"
  />

  <ComparisonTable
    title="Site Prezentare"
    subtitle="WordPress / Astro / Hugo / Custom — toate pachetele includ: configurare server cu SSL, domeniu, email."
    includedNote="Preț la cerere — ofertă personalizată în funcție de cerințe."
    planNames={['Plan 1', 'Plan 2', 'Plan 3']}
    recommendedIndex={1}
    rows={sitePrezentareRows}
    ctaHref="/contact"
    background="muted"
  />

  <ComparisonTable
    title="Magazin Online"
    subtitle="WordPress / Shopify — te ajutăm să iei cea mai bună decizie de platformă. Toate pachetele includ: configurare server cu SSL, domeniu, email."
    includedNote="Preț la cerere — ofertă personalizată în funcție de numărul de produse și complexitate."
    planNames={['Plan 1', 'Plan 2', 'Plan 3']}
    recommendedIndex={2}
    rows={magazinRows}
    ctaHref="/contact"
    background="default"
  />

  <FeaturesSection
    title="Servicii Web suplimentare"
    subtitle="Audit, landing page și mentenanță lunară."
    features={extraWebFeatures}
    background="muted"
  />

  <CTA
    title="Vrei un site sau un magazin online?"
    description="Spune-ne ce ai nevoie și îți trimitem o ofertă fără obligații."
    action={{ label: 'Solicită o ofertă', href: '/contact' }}
    background="default"
  />
</MarketingLayout>
