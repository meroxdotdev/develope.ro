---
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import PageHeader from '@sections/content/PageHeader.astro';
import ValuesSection from '@sections/team/ValuesSection.astro';
import CTA from '@sections/marketing/CTA.astro';
import { siteConfig } from '@/config';

const values = [
  {
    title: 'Calitate și transparență',
    description: 'Lucrăm cu tehnologii dovedite și oferim oferte clare, fără costuri ascunse.',
  },
  {
    title: 'Suport în română',
    description: 'Comunicare directă în limba română, de la primul contact până la livrare și mentenanță.',
  },
  {
    title: 'Soluții adaptate',
    description: 'Fiecare proiect este abordat individual — nu lucrăm „la catalog”, ci după nevoile tale.',
  },
  {
    title: 'Fiabilitate',
    description: 'Infrastructură și practici care asigură stabilitate și securitate pe termen lung.',
  },
];
---

<MarketingLayout
  title={`Despre noi — ${siteConfig.name}`}
  description="Developero — soluții IT complete pentru afacerea ta. Despre echipa și valorile noastre."
>
  <PageHeader
    title="Despre Developero"
    subtitle="Suntem partenerul tău IT pentru proiecte web, infrastructură și externalizare. Lucrăm cu companii și antreprenori care au nevoie de soluții clare, livrate la timp și cu suport în română."
    align="left"
    maxWidth="lg"
  />

  <ValuesSection
    title="Valorile noastre"
    items={values}
    variant="card"
    columns={2}
    background="muted"
  />

  <CTA
    title="Vrei să colaborăm?"
    description="Spune-ne ce ai nevoie și îți răspundem cu o ofertă sau un plan de lucru."
    action={{ label: 'Contactează-ne', href: '/contact' }}
    background="default"
  />
</MarketingLayout>
